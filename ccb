               <polygon points="14,2 26,24 2,24" fill="#f59e0b" stroke="#92400e" stroke-width="1.5"/>
               <text x="14" y="21" text-anchor="middle" font-size="13" font-weight="bold" fill="white">!</text>
             </svg>`,
        iconSize:[28,28],iconAnchor:[14,28],popupAnchor:[0,-28]
    });
}

function updateLegend(prefix, filtered) {
    const counts = {Norte:0,Sul:0,Leste:0,Oeste:0,Centro:0};
    filtered.forEach(x=>{ if(counts[x.regiao]!==undefined) counts[x.regiao]++; });
    ['Norte','Sul','Leste','Oeste','Centro'].forEach(r=>{
        const el = document.getElementById(`cnt-${prefix}-${r.toLowerCase()}`);
        if(el) el.textContent = counts[r];
    });
    const tot = document.getElementById(`total-${prefix}`);
    if(tot) tot.textContent = `Total: ${filtered.length} igrejas`;
}

// ─── ABA 1 — DISTRIBUIÇÃO ATUAL ──────────────────────────────────────────────
let map, markerCluster, selectedDays = [];

function initMap() {
    map = L.map('map',{maxBounds:mauaBounds,maxBoundsViscosity:1.0,minZoom:12}).setView([-23.6687,-46.4614],13);
    getTileLayer().addTo(map);
    markerCluster = L.markerClusterGroup();
    map.addLayer(markerCluster);
    renderContent();
}

function renderContent() {
    markerCluster.clearLayers();
    document.getElementById('churchList').innerHTML = '';
    const filtered = igrejasData.filter(c=>selectedDays.length===0||selectedDays.some(d=>c.dias.includes(d)));
    updateLegend('c', filtered);
    if(!filtered.length){document.getElementById('churchList').innerHTML='<div class="empty-state">Nenhuma igreja encontrada.</div>';return;}
    filtered.forEach(ig=>{
        const c=CORES[ig.regiao]||CORES.Oeste;
        L.marker([ig.lat,ig.lng],{icon:makeColorIcon(c.pin)})
         .bindPopup(`<b>${ig.bairro}</b><br>${ig.endereco}<br><span style="color:${c.pin};font-weight:700">${ig.regiao}</span>`)
         .addTo(markerCluster);
        const card=document.createElement('div');
        card.className='church-card';
        card.style.borderLeftColor=c.pin;
        card.innerHTML=`
          <div>
            <div class="card-header-row">
              <h3>${ig.bairro}</h3>
              <span class="region-tag" style="background:${c.pin}">${ig.regiao}</span>
            </div>
            <p>${ig.endereco}</p>
          </div>
          <div class="days">${ig.dias.map(d=>`<span class="day-tag">${d}</span>`).join('')}</div>`;
        document.getElementById('churchList').appendChild(card);
    });
}

document.getElementById('dayFilters').addEventListener('click',e=>{
    if(!e.target.classList.contains('filter-btn'))return;
    const day=e.target.getAttribute('data-day');
    if(selectedDays.includes(day)){selectedDays=selectedDays.filter(d=>d!==day);e.target.classList.remove('active');}
    else{selectedDays.push(day);e.target.classList.add('active');}
    renderContent();
});

