// ─── ABA 3 — ENSAIOS ─────────────────────────────────────────────────────────
let mapEnsaio, clusterEnsaio, mapEnsaioReady=false, selectedRegion='Todas';

function initMapEnsaio() {
    if(mapEnsaioReady)return; mapEnsaioReady=true;
    mapEnsaio=L.map('map-ensaio',{maxBounds:mauaBounds,maxBoundsViscosity:1.0,minZoom:12}).setView([-23.6687,-46.4614],13);
    getTileLayer().addTo(mapEnsaio);
    clusterEnsaio=L.markerClusterGroup();
    mapEnsaio.addLayer(clusterEnsaio);
    renderEnsaios();
}

function renderEnsaios() {
    clusterEnsaio.clearLayers();
    document.getElementById('ensaioList').innerHTML='';
    const filtered=ensaiosData.filter(e=>selectedRegion==='Todas'||e.regiao===selectedRegion);
    // legenda ensaios
    const counts={Norte:0,Sul:0,Leste:0,Oeste:0,Centro:0};
    filtered.forEach(x=>{if(counts[x.regiao]!==undefined)counts[x.regiao]++;});
    ['Norte','Sul','Leste','Oeste','Centro'].forEach(r=>{
        const el=document.getElementById(`cnt-e-${r.toLowerCase()}`);
        if(el)el.textContent=counts[r];
    });
    document.getElementById('total-ensaios').textContent=`Total: ${filtered.length} locais`;
    if(!filtered.length){document.getElementById('ensaioList').innerHTML='<div class="empty-state">Nenhum ensaio encontrado.</div>';return;}
    filtered.forEach(e=>{
        const c=CORES[e.regiao]||CORES.Oeste;
        L.marker([e.lat,e.lng],{icon:makeColorIcon(c.pin)})
         .bindPopup(`<b>${e.bairro}</b><br>🎵 ${e.ensaio} — ${e.horario}`)
         .addTo(clusterEnsaio);
        const card=document.createElement('div');
        card.className='ensaio-card';
        card.innerHTML=`
          <div class="ensaio-card-header" style="background:${c.pin}">
            <span>${e.bairro}</span>
            <span class="ensaio-regiao-badge">${e.regiao}</span>
          </div>
          <div class="ensaio-card-body">
            <div class="ensaio-row"><span class="label">📅 Ensaio</span><span class="value">${e.ensaio}</span></div>
            <div class="ensaio-row"><span class="label">🕐 Horário</span><span class="horario-pill" style="background:${c.bg};color:${c.text}">${e.horario}</span></div>
          </div>`;
        document.getElementById('ensaioList').appendChild(card);
    });
}

function filterRegion(btn) {
    selectedRegion=btn.getAttribute('data-region');
    document.querySelectorAll('.region-filter-btn').forEach(b=>{
        b.classList.remove('active');b.style.background='';b.style.color='';
    });
    btn.classList.add('active');
    const c=CORES[selectedRegion];
    if(c){btn.style.background=c.pin;btn.style.color='#fff';btn.style.borderColor=c.pin;}
    else{btn.style.background='#1e293b';btn.style.color='#fff';btn.style.borderColor='#1e293b';}
    renderEnsaios();
}

