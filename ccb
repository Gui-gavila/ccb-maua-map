// ─── TABS ─────────────────────────────────────────────────────────────────────
function switchTab(tab, btn) {
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel-'+tab).classList.add('active');
    const resize=(m)=>setTimeout(()=>{if(m)m.invalidateSize();},200);
    if(tab==='cultos')  resize(map);
    if(tab==='nova')    {initMapNova();     resize(mapNova);}
    if(tab==='ensaios') {initMapEnsaio();   resize(mapEnsaio);}
    if(tab==='semigreja'){initMapSemIgreja();resize(mapSemIgreja);}
}

window.onload = initMap;
