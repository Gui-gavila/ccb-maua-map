function agruparNova(data) {
    const mapa = {};
    data.forEach(r => {
        if (!mapa[r.bairro]) mapa[r.bairro] = { bairro:r.bairro, endereco:r.endereco, lat:r.lat, lng:r.lng, dias:[] };
        mapa[r.bairro].dias.push(r.dia);
    });
    return Object.values(mapa).map(i=>({...i,dias:[...i.dias,"Domingo"],regiao:getRegiao(i.bairro)}));
}
